# Copy to .env.development or .env.production and fill in values
# Load order: .env.<environment> first, then .env as fallback
NODE_ENV=development

FURNIGO_OLTP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
FURNIGO_API_AUTH_JWT_SECRET=local-dev-secret-change-in-production-must-be-32chars
FURNIGO_API_SERVICE_PORT=9411
FURNIGO_BLOB_BASE_URL=http://localhost:9413/api/dev/blob

# Cloudflare R2 (optional in dev)
FURNIGO_R2_ENDPOINT=
FURNIGO_R2_ACCESS_KEY=
FURNIGO_R2_SECRET_KEY=
FURNIGO_R2_BUCKET=

# AWS SES (optional in dev)
FURNIGO_SES_REGION=
FURNIGO_SES_FROM_EMAIL=

# Set email domain to bypass OTP in dev (e.g. example.com)
FURNIGO_OTP_BYPASS_DOMAIN=

# Blob CDN base URL (optional, falls back to /api/uploads)
FURNIGO_BLOB_BASE_URL=

# Mobile app (used by scripts/run-mobile.sh → --dart-define)
FURNIGO_API_BASE_URL=http://localhost:9411/api
FURNIGO_WS_URL=http://localhost:9411
