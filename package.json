{
  "name": "furnigo",
  "private": true,
  "scripts": {
    "api": "pnpm --filter @furnigo/api dev",
    "admin": "pnpm --filter @furnigo/admin dev",
    "mobile": "bash scripts/run-mobile.sh",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @furnigo/db generate",
    "db:migrate": "pnpm --filter @furnigo/db migrate"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
